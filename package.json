{
  "name": "playwright-orangehrm-framework",
  "version": "1.0.0",
  "description": "Playwright automation framework for OrangeHRM using JavaScript",
  "main": "index.js",
  "scripts": {
    "test": "npx playwright test",
    "test:ui": "npx playwright test --project=chromium",
    "test:api": "npx playwright test --project=api",
    "test:hybrid": "npx playwright test --grep @hybrid",
    "test:smoke": "npx playwright test --grep @smoke",
    "test:headed": "npx playwright test --headed",
    "test:report": "npx playwright show-report"
  },
  "keywords": [
    "playwright",
    "automation",
    "testing",
    "orangehrm"
  ],
  "author": "Chintha Bala Narasimhulu",
  "license": "ISC",
  "type": "commonjs",
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "dotenv": "^16.6.1"
  }
}